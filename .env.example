# LLM Provider
LLM_PROVIDER=openai
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
LLM_MODEL=gpt-4o-mini

# LangSmith
LANGCHAIN_TRACING_V2=true
LANGSMITH_API_KEY=
LANGCHAIN_PROJECT=fraud-monitor-agents
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# Server
HOST=0.0.0.0
PORT=8001

# Agent Config
AGENT_TIMEOUT_SECONDS=30
MAX_AGENT_RETRIES=2
